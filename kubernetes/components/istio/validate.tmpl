#!/bin/bash

set -euo pipefail

NAMESPACE="{{ if .IstioSystemNamespace }}{{ .IstioSystemNamespace }}{{ else }}istio-system{{ end }}"
TIMEOUT_SECONDS="${TIMEOUT_SECONDS:-600}"
SLEEP_SECONDS="${SLEEP_SECONDS:-10}"

echo "Validating Istio deployment in namespace ${NAMESPACE} (timeout: ${TIMEOUT_SECONDS}s)..."

if ! command -v kubectl >/dev/null 2>&1; then
  echo "Error: kubectl not found in PATH"
  exit 1
fi

start_ts=$(date +%s)

while true; do
  now_ts=$(date +%s)
  elapsed=$((now_ts - start_ts))
  if [ "${elapsed}" -ge "${TIMEOUT_SECONDS}" ]; then
    echo "Error: timeout waiting for Istio pods to be Ready in namespace ${NAMESPACE}"
    kubectl get pods -n "${NAMESPACE}" || true
    exit 1
  fi

  # Get all pods in target namespace
  pods_json=$(kubectl get pods -n "${NAMESPACE}" -o json 2>/dev/null || true)
  pod_count=$(echo "${pods_json}" | jq '.items | length' 2>/dev/null || echo "0")

  if [ "${pod_count}" -eq 0 ]; then
    echo "Error: no pods found in namespace ${NAMESPACE}, Istio appears not installed correctly"
    exit 1
  fi

  # Check pod conditions
  not_ready=$(echo "${pods_json}" | jq '.items[]
    | select(.status.phase != "Running")
      // select(.status.containerStatuses[]? | .ready != true)
    | .metadata.name' -r 2>/dev/null || true)

  if [ -z "${not_ready}" ]; then
    echo "All Istio pods in namespace ${NAMESPACE} are Ready."
    kubectl get pods -n "${NAMESPACE}"
    exit 0
  fi

  echo "Still waiting for Istio pods to be Ready in namespace ${NAMESPACE}..."
  echo "${not_ready}" | sed 's/^/  - /'
  sleep "${SLEEP_SECONDS}"
done

