#!/bin/bash

set -euo pipefail

NAMESPACE="{{ if .namespace }}{{ .namespace }}{{ else }}external-secrets{{ end }}"
TIMEOUT_SECONDS="${TIMEOUT_SECONDS:-600}"
SLEEP_SECONDS="${SLEEP_SECONDS:-10}"

echo "Validating External Secrets Operator in namespace ${NAMESPACE} (timeout: ${TIMEOUT_SECONDS}s)..."

if ! command -v kubectl >/dev/null 2>&1; then
  echo "Error: kubectl not found in PATH"
  exit 1
fi

start_ts=$(date +%s)

while true; do
  now_ts=$(date +%s)
  elapsed=$((now_ts - start_ts))
  if [ "${elapsed}" -ge "${TIMEOUT_SECONDS}" ]; then
    echo "Error: timeout waiting for External Secrets Operator pods to be Ready in namespace ${NAMESPACE}"
    kubectl get pods -n "${NAMESPACE}" || true
    exit 1
  fi

  pods_json=$(kubectl get pods -n "${NAMESPACE}" -l "app.kubernetes.io/name=external-secrets" -o json 2>/dev/null || true)
  pod_count=$(echo "${pods_json}" | jq '.items | length' 2>/dev/null || echo "0")

  if [ "${pod_count}" -eq 0 ]; then
    echo "Error: no External Secrets Operator pods found in namespace ${NAMESPACE}"
    exit 1
  fi

  not_ready=$(echo "${pods_json}" | jq '.items[]
    | select(.status.phase != "Running")
      // select(.status.containerStatuses[]? | .ready != true)
    | .metadata.name' -r 2>/dev/null || true)

  if [ -z "${not_ready}" ]; then
    echo "External Secrets Operator pods are Ready in namespace ${NAMESPACE}."
    kubectl get pods -n "${NAMESPACE}" -l "app.kubernetes.io/name=external-secrets"
    exit 0
  fi

  echo "Still waiting for External Secrets Operator pods to be Ready in namespace ${NAMESPACE}..."
  echo "${not_ready}" | sed 's/^/  - /'
  sleep "${SLEEP_SECONDS}"
done

