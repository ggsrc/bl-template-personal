apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
namespace: {{ if .Namespace }}{{ .Namespace }}{{ else }}argocd{{ end }}

resources:
- namespace.yaml
- github-ssh-sealed-secret.yaml
- {{ if .ArgoCDManifestURL }}{{ .ArgoCDManifestURL }}{{ else }}https://raw.githubusercontent.com/argoproj/argo-cd/v2.11.7/manifests/install.yaml{{ end }}

# app-namespace.yaml 与顶层 namespace 同时存在时，kustomize 会把两个 Namespace 都变成同一 name 导致 ID conflict，故默认不包含。
# 若需单独创建 app namespace，请用单独 kustomization 或 kubectl apply -f app-namespace.yaml
# - app-namespace.yaml

patchesStrategicMerge:
  # Configure rbac policy - Give galaxy org users admin access
  - argocd-rbac-cm.yaml

  # Configure argocd server
  - argocd-cmd-params-cm.yaml

patches:
- path: argocd-cm.yaml
