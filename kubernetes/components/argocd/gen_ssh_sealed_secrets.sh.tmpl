#!/bin/bash

set -euo pipefail

# 生成 SSH sealed secret 的脚本
# 使用方法: ./gen_ssh_sealed_secrets.sh <path_to_ssh_private_key>

if [ $# -eq 0 ]; then
    echo "使用方法: $0 <path_to_ssh_private_key>"
    echo "例如: $0 ~/.ssh/id_rsa"
    exit 1
fi

SSH_KEY_PATH="$1"

if [ ! -f "$SSH_KEY_PATH" ]; then
    echo "错误: SSH private key 文件不存在: $SSH_KEY_PATH"
    exit 1
fi

# 检查是否安装了 kubeseal
if ! command -v kubeseal &> /dev/null; then
    echo "错误: kubeseal 未安装。请先安装 kubeseal。"
    echo "安装方法:"
    echo "  macOS: brew install kubeseal"
    echo "  Linux: 从 https://github.com/bitnami-labs/sealed-secrets/releases 下载"
    exit 1
fi

# 检查 kubectl 连接
if ! kubectl cluster-info &> /dev/null; then
    echo "错误: 无法连接到 Kubernetes 集群。请确保 kubectl 配置正确。"
    exit 1
fi

# 显示当前集群上下文
CURRENT_CONTEXT=$(kubectl config current-context)
echo "当前 Kubernetes 上下文: $CURRENT_CONTEXT"
echo "警告: 请确保连接到正确的集群（生产环境）"
echo ""

echo "正在生成 SSH sealed secret..."

# 读取 SSH private key
SSH_PRIVATE_KEY=$(cat "$SSH_KEY_PATH")

# Create temporary secret file (do NOT include useSshAgent - causes "SSH agent requested but SSH_AUTH_SOCK not-specified" in declarative config)
# Use base64 encoding compatible with macOS and Linux
SSH_PRIVATE_KEY_B64=$(printf '%s' "$SSH_PRIVATE_KEY" | base64 | tr -d '\n')

cat > /tmp/ssh-secret.yaml << EOF
apiVersion: v1
kind: Secret
metadata:
  name: argocd-github-ssh-secret
  namespace: argocd
type: Opaque
data:
  sshPrivateKey: ${SSH_PRIVATE_KEY_B64}
EOF

# 使用 kubeseal 加密
kubeseal -f /tmp/ssh-secret.yaml -w github-ssh-sealed-secret.yaml

# 清理临时文件
rm /tmp/ssh-secret.yaml

echo "SSH sealed secret 已生成: github-ssh-sealed-secret.yaml"
echo ""
echo "接下来需要："
echo "1. 确保 GitHub repository 已添加对应的 SSH public key 作为 deploy key"
echo "2. 部署更新后的 ArgoCD 配置"
echo "3. 验证 ArgoCD 能够访问 repository"
