# Terraform entrypoint for {{ .project_name }}
# Backend and provider are in backend.tf and provider.tf respectively.

locals {
  project_id   = var.project_id
  region       = var.region
  project_name = "{{ .project_name }}"
  {{ if .domain }}domain   = "{{ .domain }}"
  {{ end }}
  vpc_name = google_compute_network.main.name
}

