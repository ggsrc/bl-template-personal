apiVersion: v1
kind: Service
metadata:
  name: APP_NAME
  labels:
    app: APP_NAME
    version: APP_VERSION
spec:
  {{- if .ServicePorts }}
  ports:
    {{- range .ServicePorts }}
    - name: {{ .name }}
      port: {{ .port }}
      targetPort: {{ .targetPort }}
    {{- end }}
  {{- else }}
  ports:
    - name: http-rest
      port: 3000
      targetPort: 3000
    - name: http
      port: 8080
      targetPort: 8080
    - name: grpc
      port: 9090
      targetPort: 9090
    - name: grpc-mtls
      port: 9091
      targetPort: 9091
    - name: http-prometheus
      port: 4014
      targetPort: 4014
  {{- end }}
  selector:
    app: APP_NAME
    version: APP_VERSION
  type: ClusterIP
