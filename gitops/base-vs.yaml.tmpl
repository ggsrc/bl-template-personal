apiVersion: networking.istio.io/v1alpha3
kind: VirtualService
metadata:
  name: {{ .ApplicationName | default "APP_NAME" }}
spec:
  hosts:
    - {{ .ApplicationName | default "APP_NAME" }}.{{ .ApplicationNamespace | default "app" }}.svc.cluster.local
  gateways:
    - mesh
  http:
    - name: http
      match:
      - port: 80
        gateways:
          - mesh
      retries:
        attempts: 3
        perTryTimeout: "10s"
      route:
        - destination:
            host: {{ .ApplicationName | default "APP_NAME" }}.{{ .ApplicationNamespace | default "app" }}.svc.cluster.local
            port:
              number: 8080
          weight: 100
    - name: grpc
      match:
      - port: 9090
        gateways:
          - mesh
      retries:
        attempts: 2
        perTryTimeout: "30s"
      route:
        - destination:
            host: {{ .ApplicationName | default "APP_NAME" }}.{{ .ApplicationNamespace | default "app" }}.svc.cluster.local
            port:
              number: 9090
          weight: 100
    - name: grpc-mtls
      match:
      - port: 9091
        gateways:
          - mesh
      retries:
        attempts: 2
        perTryTimeout: "30s"
      route:
        - destination:
            host: {{ .ApplicationName | default "APP_NAME" }}.{{ .ApplicationNamespace | default "app" }}.svc.cluster.local
            port:
              number: 9091
          weight: 100
